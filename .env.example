APP_NAME="Nutech Paper Products"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/nutech-paper-products-static-website
APP_TIMEZONE=Asia/Kolkata

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nutech_cms
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
AUTO_SYNC_ON_BOOT=true

SESSION_NAME=nutech_session
SESSION_LIFETIME=120

UPLOAD_DIR=public/uploads
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_EXT=jpg,jpeg,png,webp,gif,svg,pdf
