APP_NAME="Nutech Paper Products"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/nutech-paper-products-static-website
# Path prefix where the app is mounted (e.g. /nutech-paper-products-static-website). Leave empty for domain root.
APP_BASE_PATH=
# true = generate absolute links/assets (https://example.com/...), false = root-relative (/assets/...)
APP_USE_ABSOLUTE_URLS=false
# true = 301 redirect requests from detected install folder path to APP_BASE_PATH
APP_REDIRECT_TO_BASE_PATH=false
APP_TIMEZONE=Asia/Kolkata

DB_CONNECTION=mysql
# mysql|mariadb (mariadb is treated as mysql for PDO DSN)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nutech_cms
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
AUTO_SYNC_ON_BOOT=true
AUTO_SYNC_CREATE_DATABASE=false

SESSION_NAME=nutech_session
SESSION_LIFETIME=120

UPLOAD_DIR=public/uploads
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_EXT=jpg,jpeg,png,webp,gif,svg,pdf
